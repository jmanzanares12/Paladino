---
const navLinks = [
    { name: "Inicio", href: "/" },
    { name: "Servicios", href: "#services" },
    { name: "Precios", href: "#prices" },
    { name: "Blog", href: "#blogs" },
];
---

<nav class="fixed top-0 w-full z-50 border-b border-white/[0.03] bg-brand-dark/60 backdrop-blur-md transition-all duration-300">
    <div class="max-w-7xl mx-auto px-6 h-20 md:h-24 flex items-center justify-between">
        
        <a href="/" class="flex items-center gap-3 group">
            <div
                class="w-10 h-10 bg-brand-primary rounded-xl flex items-center justify-center font-black text-xl text-brand-dark group-hover:rotate-6 group-hover:scale-110 transition-all duration-300 shadow-lg shadow-brand-primary/20"
            >
                P
            </div>
            <span class="text-xl font-black tracking-tighter text-white italic"
                >PALADIN<span class="text-brand-primary not-italic">.</span>BUILD</span
            >
        </a>

        <div class="hidden md:flex items-center gap-10">
            {
                navLinks.map((link) => (
                    <a
                        href={link.href}
                        class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 hover:text-brand-primary transition-colors relative group"
                    >
                        {link.name}
                        <span class="absolute -bottom-1 left-0 w-0 h-px bg-brand-primary group-hover:w-full transition-all duration-300"></span>
                    </a>
                ))
            }
            
            <a
                href="#contact"
                class="relative inline-flex items-center justify-center px-6 py-3 overflow-hidden font-black text-xs uppercase tracking-widest text-white transition duration-300 ease-out bg-brand-primary/10 border border-brand-primary/20 rounded-xl group"
            >
                <span class="absolute inset-0 flex items-center justify-center w-full h-full text-brand-dark duration-300 -translate-x-full bg-brand-primary group-hover:translate-x-0 ease">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </span>
                <span class="absolute flex items-center justify-center w-full h-full text-brand-primary transition-all duration-300 transform group-hover:translate-x-full ease">Empezar Proyecto</span>
                <span class="relative invisible">Empezar Proyecto</span>
            </a>
        </div>

        <button class="md:hidden p-2 rounded-lg bg-white/5 text-brand-primary border border-white/10" aria-label="Abrir menú">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M4 8h16M8 16h12"></path>
            </svg>
        </button>
    </div>
</nav>