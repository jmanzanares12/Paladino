---
const planes = [
    {
        nombre: "Landing Page",
        precio: "250",
        sub: "Atrae Clientes y conviértalos en ventas",
        checks: [
            "Diseño personalizado que destaca",
            "Optimización para conversiones",
            "Experiencia de usuario intuitiva",
            "Contenido claro y directo",
        ],
        popular: false,
    },
    {
        nombre: "Web Estática",
        precio: "500",
        sub: "Impulsa tu negocio con una web",
        checks: [
            "Carga veloz (Astro + Vite)",
            "Cinco secciones informativas",
            "Diseño responsivo y atractivo",
            "Contenido conciso y relevante",
            "Interfaz amigable (UI/UX)",
        ],
        popular: true,
    },
    {
        nombre: "Aplicación Web",
        precio: "1000",
        sub: "Gestiona tu negocio",
        checks: [
            "Funcionalidades escalables",
            "Integración de base de datos",
            "Soporte multi-plataforma",
            "Optimización de rendimiento",
            "Panel de administración",
        ],
        popular: false,
    },
];
---

<section id="prices" class="py-16 md:py-24 lg:py-32 relative overflow-hidden">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-brand-primary/5 blur-[120px] -z-10"></div>

    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16 md:mb-24">
            <h2 class="text-5xl md:text-7xl font-black mb-6 italic tracking-tighter">
                Nuestros <span class="text-white not-italic">Precios</span>
            </h2>
            <p class="text-slate-400 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
                Inversión transparente en <span class="text-white font-bold tracking-tight">DÓLARES AMERICANOS (USD)</span>. 
                Sin letras pequeñas, solo resultados de élite.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 items-stretch">
            {planes.map((p) => (
                <div 
                    class={`relative flex flex-col p-8 md:p-10 rounded-[2.5rem] border transition-all duration-500 hover:-translate-y-2 group ${
                        p.popular 
                        ? "bg-gradient-to-b from-brand-card/80 to-brand-dark border-brand-primary/40 shadow-[0_20px_50px_rgba(14,165,233,0.1)] shadow-brand-primary/10" 
                        : "bg-brand-card border-white/5 hover:border-white/20"
                    }`}
                >
                    {p.popular && (
                        <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brand-primary text-white text-[10px] font-black uppercase tracking-[0.2em] px-4 py-1.5 rounded-full shadow-lg">
                            Más Elegido
                        </span>
                    )}
                    
                    <div class="mb-10 text-center">
                        <h3 class="text-xs font-black tracking-[0.3em] text-brand-primary mb-6 uppercase">
                            {p.nombre}
                        </h3>
                        <div class="flex items-start justify-center">
                            <span class="text-2xl font-bold mt-2 text-brand-primary/80">$</span>
                            <span class="text-6xl md:text-7xl font-black tracking-tighter text-white">
                                {p.precio}
                            </span>
                        </div>
                        <p class="text-slate-500 text-[10px] mt-4 italic uppercase tracking-widest font-bold">
                            Pago único por proyecto
                        </p>
                    </div>

                    <div class="h-px w-full bg-gradient-to-r from-transparent via-white/10 to-transparent mb-10"></div>

                    <ul class="space-y-5 mb-12 flex-grow">
                        {p.checks.map((check) => (
                            <li class="flex items-start gap-4 text-slate-300 text-sm">
                                <span class="flex-shrink-0 w-5 h-5 rounded-lg bg-brand-primary/10 border border-brand-primary/20 flex items-center justify-center text-brand-primary">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                </span>
                                <span class="leading-tight">{check}</span>
                            </li>
                        ))}
                    </ul>

                    <a 
                        href="#contact" 
                        class={`text-center py-5 rounded-2xl font-black text-xs uppercase tracking-[0.2em] transition-all duration-300 ${
                            p.popular 
                            ? "bg-brand-primary text-white hover:bg-brand-primary/90 hover:scale-[1.02] shadow-xl shadow-brand-primary/20" 
                            : "bg-white/[0.03] text-white border border-white/10 hover:bg-white/10 hover:border-white/20"
                        }`}
                    >
                        Solicitar Proyecto
                    </a>
                </div>
            ))}
        </div>
    </div>
</section>