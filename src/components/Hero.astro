---

---

<section class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden">
    <div class="absolute inset-0 -z-10">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] bg-brand-primary/20 blur-[120px] rounded-full opacity-50" >
        </div>
        <div
            class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-brand-accent/10 blur-[100px] rounded-full"
        >
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 text-slate-400 text-xs font-medium mb-8 animate-fade-in">
            <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
            Disponibles para nuevos proyectos
        </div>

        <h1 class="text-6xl md:text-[120px] font-black tracking-tighter leading-[0.85] mb-8">
            PALADIN<span class="text-brand-primary">.</span>BUILD
        </h1>

        <p class="text-slate-400 text-lg md:text-2xl max-w-3xl mx-auto leading-relaxed mb-12 font-light">
            Forjamos <span class="text-white font-medium">software de alto rendimiento</span> y experiencias digitales que protegen y escalan tu visión empresarial.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
            <a
                href="#contacto"
                class="group relative px-8 py-4 bg-brand-primary text-white font-bold rounded-2xl transition-all hover:scale-105 overflow-hidden"
            >
                <span class="relative z-10">Iniciar Proyecto</span>
                <div
                    class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-500"
                >
                </div>
            </a>
            <a
                href="#servicios"
                class="text-slate-400 hover:text-white font-bold transition-colors"
            >
                Explorar nuestro Arsenal
            </a>
        </div>
    </div>
</section>
