---
import { Icon } from "astro-icon/components";

const socialLinks = [
    { 
        name: 'X', 
        icon: 'simple-icons:x',
        href: 'https://x.com/paladindotbuild' 
    },
    { 
        name: 'LinkedIn', 
        icon: 'lucide:linkedin', 
        href: 'https://www.linkedin.com/company/paladindotbuild/' 
    },
    { 
        name: 'Instagram', 
        icon: 'lucide:instagram', 
        href: 'https://www.instagram.com/paladindotbuild' 
    },
];
---

<footer class="pt-24 pb-12 border-t border-white/5 bg-brand-dark relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-brand-primary/20 to-transparent"></div>
    
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-20">
            
            <div class="col-span-1 md:col-span-2">
                <h2 class="text-3xl font-black mb-6 tracking-tighter italic">
                    PALADIN<span class="text-brand-primary not-italic">.</span>BUILD
                </h2>
                <p class="text-slate-400 max-w-sm mb-8 leading-relaxed text-sm md:text-base">
                    Diseño y desarrollo de élite. Forjamos el futuro digital de empresas que no se conforman con lo ordinario.
                </p>
                
                <div class="flex gap-3">
                    {socialLinks.map((social) => (
                        <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.name}
                            class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center hover:bg-brand-primary hover:text-white transition-all duration-300 group"
                        >
                            <Icon name={social.icon} class="w-5 h-5 opacity-70 group-hover:opacity-100" />
                        </a>
                    ))}
                </div>
            </div>

            <div>
                <h4 class="font-black mb-8 text-white uppercase text-[10px] tracking-[0.2em]">
                    Navegación
                </h4>
                <ul class="space-y-4 text-slate-400 text-sm">
                    {[
                        { name: 'Servicios', href: '#services' },
                        { name: 'Nuestro Proceso', href: '#steps' },
                        { name: 'Precios', href: '#prices' },
                        { name: 'Blog', href: '#blogs' }
                    ].map((link) => (
                        <li>
                            <a href={link.href} class="hover:text-brand-primary transition-colors flex items-center gap-2 group">
                                <span class="w-0 h-px bg-brand-primary group-hover:w-3 transition-all"></span>
                                {link.name}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <div>
                <h4 class="font-black mb-8 text-white uppercase text-[10px] tracking-[0.2em]">
                    Contacto
                </h4>
                <ul class="space-y-6 text-slate-400 text-sm">
                    <li class="flex items-center gap-3 group">
                        <div class="p-2 rounded-lg bg-white/5 text-brand-primary">
                            <Icon name="lucide:mail" class="w-4 h-4" />
                        </div>
                        <span class="group-hover:text-white transition-colors">paladindotbuild@gmail.com</span>
                    </li>
                    <li class="pt-2">
                        <a
                            href="#contact"
                            class="inline-flex items-center gap-2 text-brand-primary font-black text-xs uppercase tracking-widest hover:gap-4 transition-all"
                        >
                            Empezar proyecto 
                            <Icon name="lucide:arrow-right" class="w-4 h-4" />
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-slate-500 text-[10px] font-medium uppercase tracking-[0.1em]">
            <p>© 2026 Paladin.Build. Todos los derechos reservados.</p>
            <div class="flex gap-8">
                <a href="#" class="hover:text-white transition-colors">Términos</a>
                <a href="#" class="hover:text-white transition-colors">Privacidad</a>
            </div>
        </div>
    </div>
</footer>