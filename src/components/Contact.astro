---
import { Icon } from "astro-icon/components";

const chanels = [
    {
        type: "WHATSAPP",
        value: "+57 300 1439612",
        link: "https://wa.me/573001439612",
        icon: "lucide:message-circle",
    },
    {
        type: "E-MAIL",
        value: "paladindotbuild@gmail.com",
        link: "mailto:paladindotbuild@gmail.com",
        icon: "lucide:mail",
    },
];

const steps = [
    "Elije el servicio que mejor se adapte a tu meta.",
    "Cuéntanos sobre tu visión o el desafío técnico que enfrentas.",
    "Recibe una propuesta estratégica en menos de 24h.",
    "¡Iniciamos la construcción de tu activo digital!",
];
---

<section id="contact" class="py-16 md:py-24 lg:py-32 relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-brand-primary/5 blur-[100px] -z-10"></div>

    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            
            <div class="order-2 lg:order-1">
                <h2 class="text-4xl md:text-6xl font-black mb-6 italic tracking-tighter leading-none">
                    ¡Todo inicia con el <br/>
                    <span class="text-white not-italic">primer contacto!</span>
                </h2>
                <p class="text-slate-400 mb-10 max-w-lg text-sm md:text-base leading-relaxed">
                    Elije el canal que prefieras. Estamos listos para asesorarte
                    y forjar una solución única para tu negocio.
                </p>

                <div class="space-y-4 md:space-y-6">
                    {
                        chanels.map((chanel) => (
                            <a
                                href={chanel.link}
                                class="flex items-center gap-5 md:gap-6 p-6 rounded-[2rem] bg-brand-card border border-white/5 hover:border-brand-primary/40 hover:bg-brand-primary/[0.02] transition-all duration-300 group"
                            >
                                <div class="w-12 h-12 md:w-14 md:h-14 rounded-2xl bg-brand-primary/10 flex items-center justify-center text-brand-primary group-hover:scale-110 group-hover:-rotate-3 transition-transform">
                                    <Icon name={chanel.icon} class="w-6 h-6 md:w-7 md:h-7" />
                                </div>
                                <div>
                                    <span class="block text-[10px] font-black text-brand-primary tracking-[.25em] uppercase mb-1">
                                        {chanel.type}
                                    </span>
                                    <span class="text-lg md:text-xl font-bold text-white group-hover:text-brand-primary transition-colors">
                                        {chanel.value}
                                    </span>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>

            <div class="order-1 lg:order-2">
                <div class="p-8 md:p-12 rounded-[3rem] bg-brand-card border border-white/5 relative overflow-hidden">
                    <div class="absolute -top-12 -right-12 w-40 h-40 bg-brand-primary/10 blur-[60px] rounded-full"></div>
                    
                    <h3 class="text-xl md:text-2xl font-bold mb-8 text-white flex items-center gap-3">
                        <span class="w-8 h-1 bg-brand-primary rounded-full"></span>
                        Onboarding de Proyecto
                    </h3>

                    <ul class="space-y-6 md:space-y-8 relative z-10">
                        {
                            steps.map((step, index) => (
                                <li class="flex gap-5 group">
                                    <div class="flex flex-col items-center">
                                        <span class="w-8 h-8 rounded-xl bg-white/[0.03] border border-white/10 flex items-center justify-center text-xs font-black text-brand-primary group-hover:border-brand-primary/50 transition-colors">
                                            {index + 1}
                                        </span>
                                        {index !== steps.length - 1 && (
                                            <div class="w-px h-full bg-gradient-to-b from-brand-primary/30 to-transparent my-2"></div>
                                        )}
                                    </div>
                                    <p class="text-slate-300 text-sm md:text-base leading-snug pt-1">
                                        {step}
                                    </p>
                                </li>
                            ))
                        }
                    </ul>

                    <div class="mt-12 p-5 rounded-2xl bg-brand-primary/5 border border-brand-primary/10 backdrop-blur-sm">
                        <p class="text-[10px] text-brand-primary font-black uppercase tracking-[0.15em] text-center flex items-center justify-center gap-2">
                            <Icon name="lucide:calendar" class="w-4 h-4" />
                            Disponibilidad limitada: Agendar con anticipación
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>