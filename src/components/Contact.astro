---
const chanels = [
    {
        type: "WHATSAPP",
        value: "+57 300 1439612",
        link: "https://wa.me/573001439612",
        icon: "💬",
    },
    {
        type: "E-MAIL",
        value: "info@paladin.build",
        link: "mailto:info@paladin.build",
        icon: "✉️",
    },
];

const steps = [
    "Elije el servicio que necesites.",
    "Cuéntanos sobre tu proyecto o tu idea.",
    "Recibe una propuesta técnica en menos de 24h.",
    "¡Iniciamos la construcción de tu sitio!",
];
---

<section id="contact" class="py-32 bg-brand-dark">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
            <div>
                <h2 class="text-5xl font-black mb-4">
                    ¡Todo inicia con el primer contacto!
                </h2>
                <p class="text-slate-400 mb-10">
                    Elije el canal que prefieras. Estamos listos para asesorarte
                    y crear algo único para ti
                </p>

                <div class="space-y-6">
                    {
                        chanels.map((chanel) => (
                            <a
                                href={chanel.link}
                                class="flex items-center gap-6 p-6 rounded-3xl bg-brand-card border border-white/5 hover:border-brand-primary/30 transition-all group"
                            >
                                <div class="w-14 h-14 rounded-2xl bg-brand-primary/10 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">
                                    {chanel.icon}
                                </div>
                                <div>
                                    <span class="block text-[10px] font-black text-brand-primary tracking-[.2em] uppercase">
                                        {chanel.type}
                                    </span>
                                    <span class="text-xl font-bold text-white">
                                        {chanel.value}
                                    </span>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>

            <div class="p-10 rounded-[2.5rem] bg-brand-card border border-white/5 relative overflow-hidden">
                <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-primary/10 blur-[80px] rounded-full"></div>
                <h3 class="text-2xl font-bold mb-8">
                    ¿Cómo realizar tu primer contacto?
                </h3>

                <ul class="space-y-6">
                    {
                        steps.map((step, index) => (
                            <li class="flex gap-4">
                                <span class="w-6 h-6 rounded-full border border-brand-primary/40 flex items-center justify-center text-[10px] font-bold text-brand-primary shrink-0 mt-1">
                                    {index + 1}
                                </span>
                                <p class="text-slate-300 leading-tight">
                                    {step}
                                </p>
                            </li>
                        ))
                    }
                </ul>

                <div class="mt-12 p-6 rounded-2xl bg-brand-primary/5 border border-brand-primary/10">
                    <p class="text-xs text-brand-primary font-bold uppercase tracking-tighter text-center">
                        Recomendamos agendar con 1 semana de anticipación
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
