---
const pasos = [
    {
        t: "Consultoría",
        d: "Reunión inicial para entender tu visión, objetivos y desafíos comerciales.",
        p: "01",
    },
    {
        t: "Diseño UI/UX",
        d: "Forjamos interfaces intuitivas y de alta conversión alineadas a tu marca.",
        p: "02",
    },
    {
        t: "Desarrollo Élite",
        d: "Escribimos código limpio, rápido y seguro usando tecnologías modernas.",
        p: "03",
    },
    {
        t: "Lanzamiento & Soporte",
        d: "Despliegue pro y acompañamiento para asegurar el éxito de tu plataforma.",
        p: "04",
    },
];
---

<section id="steps" class="py-16 md:py-24 lg:py-28 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-brand-primary/20 to-transparent"></div>

    <div class="max-w-7xl mx-auto px-6 relative">
        <div class="text-center mb-12 md:mb-20">
            <span
                class="inline-block px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-accent text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] mb-4 md:mb-6"
            >
                Metodología de Paladín
            </span>
            <h2
                class="text-4xl sm:text-5xl md:text-7xl font-black tracking-tighter leading-[1.1] md:leading-none italic"
            >
                Tu visión<br />
                <span class="text-white not-italic"> hecha realidad.</span>
            </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
            {
                pasos.map((step) => (
                    <div class="relative group p-6 md:p-8 rounded-3xl bg-brand-card border border-white/5 hover:border-brand-primary/40 transition-all duration-300">
                        <span class="absolute top-2 right-4 text-7xl md:text-8xl lg:text-9xl font-black text-brand-primary/5 group-hover:text-brand-primary/10 transition-colors z-0 select-none">
                            {step.p}
                        </span>

                        <div class="relative z-10 pt-12 md:pt-16">
                            <h4 class="text-xl md:text-2xl font-bold mb-3 text-white group-hover:text-brand-primary transition-colors">
                                {step.t}
                            </h4>
                            <p class="text-slate-400 text-sm leading-relaxed max-w-[240px] sm:max-w-none">
                                {step.d}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>