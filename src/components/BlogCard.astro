---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props as Props;
---

<a href={`/blog/${post.slug}`} class="group block">
  <div class="rounded-3xl overflow-hidden border border-white/10">
    <img 
      src={post.data.image} 
      alt={post.data.title}
      class="w-full h-56 object-cover group-hover:scale-105 transition"
    />
  </div>

  <div class="mt-6">
    <span class="text-brand-primary text-xs font-bold uppercase tracking-widest">
      {post.data.category}
    </span>

    <h2 class="text-2xl font-black mt-2 group-hover:text-brand-primary transition">
      {post.data.title}
    </h2>

    <p class="text-slate-400 mt-2">
      {post.data.description}
    </p>
  </div>
</a>