---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Obtener posts
const posts: CollectionEntry<'blog'>[] = await getCollection('blog');

// Ordenar por fecha (más reciente primero)
const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime();
});
---

<Layout title="Blog | Paladin Build">
  <section class="pt-32 pb-20 max-w-7xl mx-auto px-6">

    <div class="flex items-center justify-between mb-16">
      <div>
        <h1 class="text-5xl md:text-7xl font-black italic uppercase">
          Blog
        </h1>
        <p class="text-slate-400 mt-4 text-lg">
          Insights, estrategias y desarrollo web moderno.
        </p>
      </div>
    </div>

    <!-- GRID -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
      {sortedPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group block">
          
          <div class="rounded-3xl overflow-hidden border border-white/10">
            <img 
              src={post.data.image} 
              alt={post.data.title}
              class="w-full h-56 object-cover group-hover:scale-105 transition"
            />
          </div>

          <div class="mt-6">
            <span class="text-brand-primary text-xs font-bold uppercase tracking-widest">
              {post.data.category}
            </span>

            <h2 class="text-2xl font-black mt-2 group-hover:text-brand-primary transition">
              {post.data.title}
            </h2>

            <p class="text-slate-400 mt-2">
              {post.data.description}
            </p>
          </div>

        </a>
      ))}
    </div>

  </section>
</Layout>